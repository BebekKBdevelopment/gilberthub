}

local RadarSettings = {
    Enabled = false,
    Size = 180,
    Position = Vector2.new(50, 50),
    DotColor = Color3.fromRGB(255, 255, 255),
    CenterColor = Color3.fromRGB(0, 255, 0),
    BackgroundColor = Color3.fromRGB(0, 0, 0),
    FriendDotColor = Color3.fromRGB(0, 255, 0),
    Reverse = true
}

