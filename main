local FriendInput = FriendsTab:AddInput("FriendInput", {
    Title = "Username",
    Placeholder = "Enter username...",
    AllowClear = true
})

FriendsTab:AddButton({
    Title = "Add Friend",
    Callback = function()
        local name = FriendInput.Value or ""
        if name ~= "" and not Friends[name] then
            Friends[name] = true
            Fluent:Notify({
                Title = "Friend Added",
                Content = name .. " added",
                Duration = 3
            })
            UpdateFriendList()
        end
    end
})

FriendsTab:AddParagraph({Title = "Your Friends", Content = ""})

local FriendListParagraph = FriendsTab:AddParagraph({Title = "", Content = "No friends yet"})

local function UpdateFriendList()
    local list = "Friends:\n"
    for friendName in pairs(Friends) do
        list = list .. "- " .. friendName .. "\n"
    end
    FriendListParagraph:Set({Content = list ~= "Friends:\n" and list or "No friends yet"})
end

FriendsTab:AddButton({
    Title = "Refresh Friend List",
    Callback = UpdateFriendList
})

local function CleanupESP(player)
    if ESPObjects[player] then
        for _, obj in pairs(ESPObjects[player]) do
            if typeof(obj) == "table" then
                for _, line in ipairs(obj) do pcall(function() line:Remove() end) end
            else
                pcall(function() obj:Remove() end)
            end
        end
        if ESPObjects[player].Highlight then
            pcall(function() ESPObjects[player].Highlight:Destroy() end)
        end
        ESPObjects[player] = nil
    end
end

local function CleanupRadar(player)
    if RadarDots[player] then
        pcall(function() RadarDots[player]:Remove() end)
        RadarDots[player] = nil
    end
end

Players.PlayerRemoving:Connect(function(player)
    CleanupESP(player)
    CleanupRadar(player)
    if AimbotSettings.LockedTarget and AimbotSettings.LockedTarget.Parent and Players:GetPlayerFromCharacter(AimbotSettings.LockedTarget.Parent) == player then
        AimbotSettings.LockedTarget = nil
    end
end)

local function CreateESP(player)
    if player == LocalPlayer then return end
    local Box = Drawing.new("Square")
    Box.Thickness = 2
    Box.Filled = false
    Box.Transparency = 1
    Box.Visible = false

    local NameTag = Drawing.new("Text")
    NameTag.Size = 16
    NameTag.Center = true
    NameTag.Outline = true
    NameTag.Transparency = 1
    NameTag.Visible = false

    local DistTag = Drawing.new("Text")
    DistTag.Size = 14
    DistTag.Center = true
    DistTag.Outline = true
    DistTag.Transparency = 1
    DistTag.Visible = false

    local TracerLine = Drawing.new("Line")
    TracerLine.Thickness = 1.5
    TracerLine.Transparency = 1
    TracerLine.Visible = false

    local SkeletonLines = {}
    for i = 1, 14 do
        local ln = Drawing.new("Line")
        ln.Thickness = ESPSettings.SkeletonThickness
        ln.Transparency = 1
        ln.Visible = false
        table.insert(SkeletonLines, ln)
    end

    ESPObjects[player] = {Box = Box, Name = NameTag, Dist = DistTag, Tracer = TracerLine, Skeleton = SkeletonLines, Highlight = nil}
end

for _, plr in Players:GetPlayers() do CreateESP(plr) end
Players.PlayerAdded:Connect(CreateESP)

local function CreateRadarDot(player)
    if player == LocalPlayer then return end
    local dot = Drawing.new("Circle")
    dot.Radius = 4
    dot.Filled = true
    dot.Transparency = 1
    dot.Visible = false
    RadarDots[player] = dot
end

for _, plr in Players:GetPlayers() do CreateRadarDot(plr) end
Players.PlayerAdded:Connect(CreateRadarDot)

local function IsValidTarget(part)
    if not part or not part.Parent then return false end
    local char = part.Parent
    local player = Players:GetPlayerFromCharacter(char)
    if not player or player == LocalPlayer then return false end
    if AimbotSettings.TeamCheck and player.Team == LocalPlayer.Team then return false end
    if Friends[player.Name] then return false end
    local hum = char:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    
    local screen, onScreen = Camera:WorldToViewportPoint(part.Position)
    if not onScreen then return false end
    local mousePos = UserInputService:GetMouseLocation()
    local dist = (Vector2.new(screen.X, screen.Y) - mousePos).Magnitude
    if dist > AimbotSettings.FOVRadius then return false end
    
    return true
end

local function GetClosestPlayerToMouse()
    local closest, minDist = nil, AimbotSettings.FOVRadius
    local mousePos = UserInputService:GetMouseLocation()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            if AimbotSettings.TeamCheck and player.Team == LocalPlayer.Team then continue end
            if Friends[player.Name] then continue end
            local part = player.Character:FindFirstChild(AimbotSettings.TargetPart) or player.Character:FindFirstChild("Head")
            if part then
                local screen, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(screen.X, screen.Y) - mousePos).Magnitude
                    if dist < minDist then
                        minDist = dist
                        closest = part
                    end
                end
            end
        end
    end
    return closest
end

UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == AimbotSettings.HoldKey then
        AimbotSettings.Holding = true
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == AimbotSettings.HoldKey then
        AimbotSettings.Holding = false
        AimbotSettings.LockedTarget = nil
    end
end)

RunService.RenderStepped:Connect(function()
    Camera.FieldOfView = CustomFOV

    if StretchResEnabled then
        Camera.CFrame = Camera.CFrame * CFrame.new(0, 0, 0, 1, 0, 0, 0, StretchAmount, 0, 0, 0, 1)
    end

    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = WalkSpeed
    end

    if AimbotSettings.ShowFOV then
        FOVCircle.Position = UserInputService:GetMouseLocation()
        FOVCircle.Radius = AimbotSettings.FOVRadius
        FOVCircle.Color = AimbotSettings.FOVColor
        FOVCircle.Thickness = AimbotSettings.FOVThickness
        FOVCircle.Visible = true
    else
        FOVCircle.Visible = false
    end

    if AimbotSettings.Enabled and AimbotSettings.Holding then
        if not AimbotSettings.LockedTarget or not IsValidTarget(AimbotSettings.LockedTarget) then
            local newTarget = GetClosestPlayerToMouse()
            if newTarget then
                AimbotSettings.LockedTarget = newTarget
            else
                AimbotSettings.LockedTarget = nil
            end
        end

        if AimbotSettings.LockedTarget and IsValidTarget(AimbotSettings.LockedTarget) then
            local targetPos = AimbotSettings.LockedTarget.Position + Vector3.new(0, 0.15, 0)
            local targetCF = CFrame.lookAt(Camera.CFrame.Position, targetPos)
            local alpha = 1 - AimbotSettings.Smoothing
            if AimbotSettings.Smoothing <= 0 then alpha = 1 end
            Camera.CFrame = Camera.CFrame:Lerp(targetCF, alpha)
        else
            AimbotSettings.LockedTarget = nil
        end
    else
        AimbotSettings.LockedTarget = nil
    end

    if ESPSettings.FullBright then
        Lighting.Brightness = 2
        Lighting.ClockTime = 14
        Lighting.FogEnd = 100000
        Lighting.GlobalShadows = false
        Lighting.Ambient = Color3.fromRGB(255,255,255)
        Lighting.OutdoorAmbient = Color3.fromRGB(200,200,200)
    else
        Lighting.Brightness = originalLighting.Brightness
        Lighting.ClockTime = originalLighting.ClockTime
        Lighting.FogEnd = originalLighting.FogEnd
        Lighting.GlobalShadows = originalLighting.GlobalShadows
        Lighting.Ambient = originalLighting.Ambient
        Lighting.OutdoorAmbient = originalLighting.OutdoorAmbient
    end

    for player, drawings in pairs(ESPObjects) do
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local head = char and char:FindFirstChild("Head")
        local hum = char and char:FindFirstChild("Humanoid")

        if not char or not root or not head or not hum or hum.Health <= 0 then
            drawings.Box.Visible = false
            drawings.Name.Visible = false
            drawings.Dist.Visible = false
            drawings.Tracer.Visible = false
            for _, line in ipairs(drawings.Skeleton) do
                line.Visible = false
            end
            if drawings.Highlight then
                drawings.Highlight.Enabled = false
            end
            
            pcall(function()
                drawings.Box:Remove()
                drawings.Name:Remove()
                drawings.Dist:Remove()
                drawings.Tracer:Remove()
                for _, line in ipairs(drawings.Skeleton) do line:Remove() end
                if drawings.Highlight then drawings.Highlight:Destroy() end
            end)
            
            ESPObjects[player] = nil
            continue
        end

        local rootPos, onScreen = Camera:WorldToViewportPoint(root.Position)

        if not onScreen then
            drawings.Box.Visible = false
            drawings.Name.Visible = false
            drawings.Dist.Visible = false
            drawings.Tracer.Visible = false
            for _, line in ipairs(drawings.Skeleton) do
                line.Visible = false
            end
            if drawings.Highlight then
                drawings.Highlight.Enabled = false
            end
            continue
        end

        local dist = (Camera.CFrame.Position - root.Position).Magnitude
        local isFriend = Friends[player.Name] or false
        local color = isFriend and ESPSettings.FriendColor or ESPSettings.BoxColor
        local tracerColor = isFriend and ESPSettings.FriendColor or ESPSettings.TracerColor
        local skelColor = isFriend and ESPSettings.FriendColor or ESPSettings.SkeletonColor

        local function w2s(pos)
            local vec, vis = Camera:WorldToViewportPoint(pos)
            return vis and Vector2.new(vec.X, vec.Y) or nil
        end

        local headOffset = head.Size.Y / 2 + 0.5
        local head2d = w2s(head.Position + Vector3.new(0, headOffset, 0))

        local leftFoot = char:FindFirstChild("LeftFoot")
        local rightFoot = char:FindFirstChild("RightFoot")
        local footOffset = leftFoot and leftFoot.Size.Y / 2 or 1
        local leftfoot2d = leftFoot and w2s(leftFoot.Position - Vector3.new(0, footOffset, 0))
        local rightfoot2d = rightFoot and w2s(rightFoot.Position - Vector3.new(0, footOffset, 0))

        local foot2d
        if leftfoot2d and rightfoot2d then
            foot2d = leftfoot2d.Y > rightfoot2d.Y and leftfoot2d or rightfoot2d
        elseif leftfoot2d or rightfoot2d then
            foot2d = leftfoot2d or rightfoot2d
        else
            foot2d = w2s(root.Position - Vector3.new(0, 3, 0))
        end

        local torso2d = w2s((char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")).Position)

        local minY = head2d and head2d.Y or rootPos.Y - 50
        local maxY = foot2d and foot2d.Y or rootPos.Y + 50
        local height_px = maxY - minY
        local width_px = height_px * 0.4
        local centerX = torso2d and torso2d.X or rootPos.X
        local minX = centerX - width_px / 2
        local maxX = centerX + width_px / 2

        if ESPSettings.Boxes then
            drawings.Box.Position = Vector2.new(minX, minY)
            drawings.Box.Size = Vector2.new(maxX - minX, maxY - minY)
            drawings.Box.Color = color
            drawings.Box.Visible = true
        else
            drawings.Box.Visible = false
        end

        if ESPSettings.Names then
            drawings.Name.Text = player.Name
            drawings.Name.Position = Vector2.new((minX + maxX) / 2, minY - 20)
            drawings.Name.Color = ESPSettings.NameColor
            drawings.Name.Visible = true
        else
            drawings.Name.Visible = false
        end

        if ESPSettings.Distance then
            drawings.Dist.Text = math.floor(dist) .. " studs"
            drawings.Dist.Position = Vector2.new((minX + maxX) / 2, maxY + 5)
            drawings.Dist.Color = ESPSettings.DistanceColor
            drawings.Dist.Visible = true
        else
            drawings.Dist.Visible = false
        end

        if ESPSettings.Tracer then
            drawings.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
            drawings.Tracer.To = Vector2.new((minX + maxX) / 2, maxY)
            drawings.Tracer.Color = tracerColor
            drawings.Tracer.Visible = true
        else
            drawings.Tracer.Visible = false
        end

        if ESPSettings.Skeleton then
            local upperTorso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
            local lowerTorso = char:FindFirstChild("LowerTorso") or upperTorso

            local parts = {
                Head = head.Position,
                UpperTorso = upperTorso and upperTorso.Position,
                LowerTorso = lowerTorso and lowerTorso.Position,
                LeftUpperArm = char:FindFirstChild("LeftUpperArm") and char.LeftUpperArm.Position,
                LeftLowerArm = char:FindFirstChild("LeftLowerArm") and char.LeftLowerArm.Position,
                LeftHand = char:FindFirstChild("LeftHand") and char.LeftHand.Position,
                RightUpperArm = char:FindFirstChild("RightUpperArm") and char.RightUpperArm.Position,
                RightLowerArm = char:FindFirstChild("RightLowerArm") and char.RightLowerArm.Position,
                RightHand = char:FindFirstChild("RightHand") and char.RightHand.Position,
                LeftUpperLeg = char:FindFirstChild("LeftUpperLeg") and char.LeftUpperLeg.Position,
                LeftLowerLeg = char:FindFirstChild("LeftLowerLeg") and char.LeftLowerLeg.Position,
                LeftFoot = char:FindFirstChild("LeftFoot") and char.LeftFoot.Position,
                RightUpperLeg = char:FindFirstChild("RightUpperLeg") and char.RightUpperLeg.Position,
                RightLowerLeg = char:FindFirstChild("RightLowerLeg") and char.RightLowerLeg.Position,
                RightFoot = char:FindFirstChild("RightFoot") and char.RightFoot.Position
            }

            local connections = {
                {parts.Head, parts.UpperTorso},
                {parts.UpperTorso, parts.LowerTorso},
                {parts.UpperTorso, parts.LeftUpperArm},
                {parts.LeftUpperArm, parts.LeftLowerArm},
                {parts.LeftLowerArm, parts.LeftHand},
                {parts.UpperTorso, parts.RightUpperArm},
                {parts.RightUpperArm, parts.RightLowerArm},
                {parts.RightLowerArm, parts.RightHand},
                {parts.LowerTorso, parts.LeftUpperLeg},
                {parts.LeftUpperLeg, parts.LeftLowerLeg},
                {parts.LeftLowerLeg, parts.LeftFoot},
                {parts.LowerTorso, parts.RightUpperLeg},
                {parts.RightUpperLeg, parts.RightLowerLeg},
                {parts.RightLowerLeg, parts.RightFoot}
            }

            local lines = drawings.Skeleton
            for i, conn in ipairs(connections) do
                if conn[1] and conn[2] then
                    local from = w2s(conn[1])
                    local to = w2s(conn[2])
                    if from and to then
                        lines[i].From = from
                        lines[i].To = to
                        lines[i].Color = skelColor
                        lines[i].Thickness = ESPSettings.SkeletonThickness
                        lines[i].Visible = true
                    else
                        lines[i].Visible = false
                    end
                else
                    lines[i].Visible = false
                end
            end
        else
            for _, ln in ipairs(drawings.Skeleton) do ln.Visible = false end
        end

        if ESPSettings.Chams then
            if not drawings.Highlight then
                drawings.Highlight = Instance.new("Highlight")
                drawings.Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                drawings.Highlight.Parent = char
            end
            drawings.Highlight.Enabled = true
            drawings.Highlight.FillColor = isFriend and ESPSettings.FriendColor or ESPSettings.ChamsFillColor
            drawings.Highlight.OutlineColor = ESPSettings.ChamsOutlineColor
            drawings.Highlight.FillTransparency = ESPSettings.ChamsFillTransparency
            drawings.Highlight.OutlineTransparency = ESPSettings.ChamsOutlineTransparency
        else
            if drawings.Highlight then
                drawings.Highlight.Enabled = false
            end
        end
    end

    if RadarSettings.Enabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local lpPos = LocalPlayer.Character.HumanoidRootPart.Position
        local center = RadarSettings.Position + Vector2.new(RadarSettings.Size / 2, RadarSettings.Size / 2)
        RadarBackground.Position = RadarSettings.Position
        RadarBackground.Size = Vector2.new(RadarSettings.Size, RadarSettings.Size)
        RadarBackground.Color = RadarSettings.BackgroundColor
        RadarBackground.Visible = true
        RadarCenterDot.Position = center
        RadarCenterDot.Color = RadarSettings.CenterColor
        RadarCenterDot.Visible = true

        for player, dot in pairs(RadarDots) do
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local diff = hrp.Position - lpPos
                local rel = Camera.CFrame:VectorToObjectSpace(diff)
                local radarX = rel.X
                local radarZ = RadarSettings.Reverse and rel.Z or -rel.Z
                local relative = Vector2.new(radarX, radarZ)
                local dist = relative.Magnitude
                local scale = RadarSettings.Size / 200
                relative = relative * scale
                if dist > (RadarSettings.Size / 2 - dot.Radius) then
                    relative = relative.Unit * (RadarSettings.Size / 2 - dot.Radius)
                end
                dot.Position = center + relative
                dot.Color = Friends[player.Name] and RadarSettings.FriendDotColor or RadarSettings.DotColor
                dot.Visible = true
            else
                dot.Visible = false
            end
        end
    else
        RadarBackground.Visible = false
        RadarCenterDot.Visible = false
        for _, dot in pairs(RadarDots) do dot.Visible = false end
    end
end)

